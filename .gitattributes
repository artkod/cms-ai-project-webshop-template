# Cross-platform line endings: normalize text to LF in the repo and on checkout
# (Windows + macOS + Linux), so shell scripts stay runnable on Unix.
* text=auto eol=lf

# Shell scripts must be LF — a CRLF shebang/line ending breaks them on macOS/Linux.
*.sh text eol=lf

# Binary assets — never line-ending-convert.
*.png binary
*.ico binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.woff binary
*.woff2 binary
